[{"id":"1eeaad8","elType":"container","settings":{"content_width":"full","padding":{"top":"0","right":"0","bottom":"0","left":"0","unit":"px","isLinked":true}},"elements":[{"id":"3768a40","elType":"widget","widgetType":"shortcode","settings":{"shortcode":"[rev_slider alias=\\"main-home\\"]"},"elements":[]}]},{"id":"d95c96c","elType":"container","settings":{"content_width":"boxed","padding":{"top":"100","right":"0","bottom":"100","left":"0","unit":"px","isLinked":false}},"elements":[{"id":"2308725","elType":"widget","widgetType":"heading","settings":{"title":"ENGINEERING CONSULTANCY","align":"center","title_color":"#999999","typography_typography":"custom","typography_font_size":{"unit":"px","size":14},"typography_letter_spacing":{"unit":"px","size":3},"typography_text_transform":"uppercase"},"elements":[]},{"id":"62d7e10","elType":"widget","widgetType":"heading","settings":{"title":"We Design the Future","align":"center","header_size":"h1","typography_typography":"custom","typography_font_size":{"unit":"px","size":52},"typography_font_weight":"600","typography_letter_spacing":{"unit":"px","size":-2}},"elements":[]},{"id":"a73525e","elType":"widget","widgetType":"text-editor","settings":{"editor":"<p style=\\"text-align:center;max-width:700px;margin:0 auto;color:#666;\\">ECEC, a prominent engineering consultancy based in Dubai, UAE, expands its presence with offices strategically located in Riyadh, KSA, and Amman, Jordan. Our team comprises a dynamic mix of professionals representing various nationalities.<\\/p>","align":"center"},"elements":[]}]},{"id":"5cb0259","elType":"container","settings":{"content_width":"boxed","padding":{"top":"80","right":"30","bottom":"80","left":"30","unit":"px","isLinked":false},"background_background":"classic","background_color":"#F8F8F8"},"elements":[{"id":"a6f2796","elType":"widget","widgetType":"heading","settings":{"title":"WHAT WE DO","align":"center","title_color":"#999999","typography_typography":"custom","typography_font_size":{"unit":"px","size":14},"typography_letter_spacing":{"unit":"px","size":3},"typography_text_transform":"uppercase"},"elements":[]},{"id":"00f4e49","elType":"widget","widgetType":"heading","settings":{"title":"Our Services","align":"center","header_size":"h3","typography_typography":"custom","typography_font_size":{"unit":"px","size":36},"typography_font_weight":"600"},"elements":[]},{"id":"7119627","elType":"widget","widgetType":"text-editor","settings":{"editor":"\\n<div style=\\"display:grid;grid-template-columns:repeat(3,1fr);gap:30px;max-width:1200px;margin:40px auto 0;\\">\\n<div style=\\"text-align:center;padding:30px 20px;\\">\\n<h4>Structural Engineering<\\/h4>\\n<p style=\\"color:#666;margin-top:10px;text-align:justify;\\">Our team of experienced structural engineers provides innovative and cost-effective solutions for a wide range of structural projects. We specialize in the design and analysis of buildings, bridges, towers, and other structures.<\\/p>\\n<\\/div>\\n<div style=\\"text-align:center;padding:30px 20px;\\">\\n<h4>MEP Engineering<\\/h4>\\n<p style=\\"color:#666;margin-top:10px;text-align:justify;\\">We offer MEP design and engineering services that cover all aspects of building services, including HVAC systems, electrical systems, plumbing systems, fire protection systems, and more.<\\/p>\\n<\\/div>\\n<div style=\\"text-align:center;padding:30px 20px;\\">\\n<h4>ICT Solutions<\\/h4>\\n<p style=\\"color:#666;margin-top:10px;text-align:justify;\\">We offer a wide range of ICT solutions and services, including network design and implementation, software development, cybersecurity, and IT consulting. Our team is committed to providing cutting-edge technology solutions that enhance productivity and efficiency.<\\/p>\\n<\\/div>\\n<div style=\\"text-align:center;padding:30px 20px;\\">\\n<h4>BIM Services<\\/h4>\\n<p style=\\"color:#666;margin-top:10px;text-align:justify;\\">Our BIM services cover the entire project lifecycle, from concept design to construction and maintenance. We use the latest BIM software to create 3D models that allow for accurate visualization, clash detection, and coordination.<\\/p>\\n<\\/div>\\n<div style=\\"text-align:center;padding:30px 20px;\\">\\n<h4>Acoustic Engineering<\\/h4>\\n<p style=\\"color:#666;margin-top:10px;text-align:justify;\\">Our acoustic engineers provide expert advice on noise and vibration control, acoustic design, and environmental acoustics. We offer comprehensive solutions that optimize acoustical performance in buildings, transportation systems, and other structures.<\\/p>\\n<\\/div>\\n<div style=\\"text-align:center;padding:30px 20px;\\">\\n<h4>Security Engineering<\\/h4>\\n<p style=\\"color:#666;margin-top:10px;text-align:justify;\\">Our security experts provide comprehensive security consulting and engineering services, including risk assessments, security system design, and physical security solutions. We work with clients to develop customized security solutions that meet their unique needs.<\\/p>\\n<\\/div>\\n<\\/div>"},"elements":[]}]},{"id":"a6ba364","elType":"container","settings":{"content_width":"boxed","padding":{"top":"100","right":"0","bottom":"20","left":"0","unit":"px","isLinked":false}},"elements":[{"id":"4c7af79","elType":"widget","widgetType":"heading","settings":{"title":"PORTFOLIO","align":"center","title_color":"#999999","typography_typography":"custom","typography_font_size":{"unit":"px","size":14},"typography_letter_spacing":{"unit":"px","size":3},"typography_text_transform":"uppercase"},"elements":[]},{"id":"3e80ce9","elType":"widget","widgetType":"heading","settings":{"title":"Featured Projects","align":"center","header_size":"h3","typography_typography":"custom","typography_font_size":{"unit":"px","size":36},"typography_font_weight":"600"},"elements":[]}]},{"id":"31566da","elType":"container","settings":{"content_width":"boxed","padding":{"top":"40","right":"0","bottom":"40","left":"0","unit":"px","isLinked":false}},"elements":[{"id":"713