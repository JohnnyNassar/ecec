a:5:{s:12:"_multiwidget";i:1;i:10;a:2:{s:5:"title";s:0:"";s:7:"content";s:923:"<div class="ecec-footer-brand">\n<h3 style="font-size:24px;font-weight:700;letter-spacing:3px;margin-bottom:20px;color:#2b2b2b;">ECEC</h3>\n<p style="font-size:14px;line-height:1.8;color:#777;">A prominent engineering consultancy based in Dubai, UAE, with offices in Riyadh and Amman. Delivering innovative solutions across MEP, Structural, ICT, BIM, Acoustics, and Security engineering.</p>\n<div style="margin-top:25px;">\n<a href="https://www.linkedin.com/company/ecec-engineering/" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border:1px solid #ccc;border-radius:50%;color:#555;text-decoration:none;font-weight:bold;font-size:14px;font-family:Georgia,serif;transition:all 0.3s ease;" onmouseover="this.style.borderColor='#0077b5';this.style.color='#0077b5'" onmouseout="this.style.borderColor='#ccc';this.style.color='#555'">in</a>\n</div>\n</div>";}i:11;a:2:{s:5:"title";s:0:"";s:7:"content";s:1571:"<div class="ecec-footer-links">\n<h6 style="font-size:11px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:#999;margin-bottom:25px;">Quick Links</h6>\n<ul style="list-style:none;padding:0;margin:0;">\n<li style="margin-bottom:12px;"><a href="/ecec/" style="color:#555;text-decoration:none;font-size:14px;transition:color 0.3s;" onmouseover="this.style.color='#000'" onmouseout="this.style.color='#555'">Home</a></li>\n<li style="margin-bottom:12px;"><a href="/ecec/about-us/" style="color:#555;text-decoration:none;font-size:14px;transition:color 0.3s;" onmouseover="this.style.color='#000'" onmouseout="this.style.color='#555'">About Us</a></li>\n<li style="margin-bottom:12px;"><a href="/ecec/our-services/" style="color:#555;text-decoration:none;font-size:14px;transition:color 0.3s;" onmouseover="this.style.color='#000'" onmouseout="this.style.color='#555'">Our Services</a></li>\n<li style="margin-bottom:12px;"><a href="/ecec/projects/" style="color:#555;text-decoration:none;font-size:14px;transition:color 0.3s;" onmouseover="this.style.color='#000'" onmouseout="this.style.color='#555'">Projects</a></li>\n<li style="margin-bottom:12px;"><a href="/ecec/people/" style="color:#555;text-decoration:none;font-size:14px;transition:color 0.3s;" onmouseover="this.style.color='#000'" onmouseout="this.style.color='#555'">People</a></li>\n<li><a href="/ecec/contact-us/" style="color:#555;text-decoration:none;font-size:14px;transition:color 0.3s;" onmouseover="this.style.color='#000'" onmouseout="this.style.color='#555'">Contact Us</a></li>\n</ul>\n</div>";}i:12;a:2:{s:5:"title";s:0:"";s:7:"content";s:1230:"<div class="ecec-footer-contact">\n<h6 style="font-size:11px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:#999;margin-bottom:25px;">Our Offices</h6>\n<div style="margin-bottom:18px;">\n<p style="font-size:14px;font-weight:600;color:#2b2b2b;margin-bottom:3px;">Dubai</p>\n<p style="font-size:13px;color:#777;margin:0;">Business Bay, Dubai, UAE</p>\n</div>\n<div style="margin-bottom:18px;">\n<p style="font-size:14px;font-weight:600;color:#2b2b2b;margin-bottom:3px;">Riyadh</p>\n<p style="font-size:13px;color:#777;margin:0;">Olaya, Riyadh, KSA</p>\n</div>\n<div style="margin-bottom:18px;">\n<p style="font-size:14px;font-weight:600;color:#2b2b2b;margin-bottom:3px;">Amman</p>\n<p style="font-size:13px;color:#777;margin:0;">Mecca Street, Amman, Jordan</p>\n</div>\n<div style="margin-top:25px;padding-top:20px;border-top:1px solid #eee;">\n<p style="font-size:13px;color:#777;margin-bottom:6px;"><strong style="color:#555;">Email:</strong> <a href="mailto:info@ecec.co" style="color:#777;text-decoration:none;">info@ecec.co</a></p>\n<p style="font-size:13px;color:#777;margin:0;"><strong style="color:#555;">HR:</strong> <a href="mailto:hr@ecec.co" style="color:#777;text-decoration:none;">hr@ecec.co</a></p>\n</div>\n</div>";}i:13;a:2:{s:5:"title";s:0:"";s:7:"content";s:519:"<d